    {
      "parameters": {
        "jsCode": "// Καθαρισμός διπλότυπων ανά Χρήστη + Μήνυμα\nconst uniqueItems = [];\nconst seenSubmissions = new Set();\n\nfor (const item of $input.all()) {\n  // Παίρνουμε το email (αν δεν υπάρχει, βάζουμε 'anonymous')\n  const email = item.json.Customer_Email ? item.json.Customer_Email.trim().toLowerCase() : \"anonymous\";\n  // Παίρνουμε το κείμενο του αιτήματος\n  const content = item.json.Raw_Content ? item.json.Raw_Content.trim().toLowerCase() : \"\";\n  \n  // Φτιάχνουμε ένα μοναδικό \"κλειδί\" π.χ. \"user@test.com_θέλω dark mode\"\n  const uniqueKey = `${email}_${content}`;\n  \n  if (!seenSubmissions.has(uniqueKey)) {\n    seenSubmissions.add(uniqueKey);\n    uniqueItems.push(item); // Κρατάμε μόνο την πρώτη φορά που εμφανίζεται αυτός ο συνδυασμός\n  }\n}\n\nreturn uniqueItems;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        -16
      ],
      "id": "1b1c076f-677a-4899-bdaa-42b14567d098",
      "name": "Duplicates Filtering"
    },
    {
      "parameters": {
        "jsCode": "// 1. Κρατάμε το raw string που επέστρεψε ο AI Agent\nlet rawOutput = $json.output;\n\n// Καθαρίζουμε τυχόν Markdown Code Blocks (```json ... ```) αν υπάρχουν στο string\nif (typeof rawOutput === 'string') {\n  rawOutput = rawOutput.replace(/```json/g, '').replace(/```/g, '').trim();\n}\n\ntry {\n  // 2. Μετατρέπουμε το string σε πραγματικό αντικείμενο (Object) για να το χωρίσουμε\n  const parsedData = JSON.parse(rawOutput);\n  \n  // 3. Χωρίζουμε το output σε αυτόνομα τμήματα (Properties) πάνω στο $json\n  // Αν το AI έβγαλε το summary ως 'feature_summary', το αντιστοιχίζουμε στο 'normalized_title' που ζητάς\n  $json.normalized_title = parsedData.normalized_title || parsedData.feature_summary || \"Feature Request\";\n  $json.urgency = parsedData.urgency || \"Low\";\n  $json.is_feature_request = parsedData.feature_request === true;\n  \n  // 4. Ξανακλειδώνουμε το αρχικό $json.output ως καθαρό JSON string \n  // για να μην σπάσει η έκφραση JSON.parse($json.output) στο επόμενο node\n  $json.output = JSON.stringify({\n    normalized_title: $json.normalized_title,\n    urgency: $json.urgency,\n    feature_request: $json.is_feature_request\n  });\n\n} catch (error) {\n  // Fallback αν το AI βγάλει εντελώς χαλασμένο string\n  $json.normalized_title = \"Feature Request (Parse Error)\";\n  $json.urgency = \"Low\";\n  $json.output = JSON.stringify({ normalized_title: $json.normalized_title, urgency: $json.urgency });\n}\n\n// 5. Τραβάμε την τιμή Customer από το Loop Over Items για να είναι διαθέσιμη\ntry {\n  $json.Customer = $node[\"Loop Over Items\"].json.Customer;\n} catch (e) {\n  $json.Customer = \"anonymous\";\n}\n\nreturn $json;"
      },
      "type": "n8n-nodes-base.code",
