    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  let rawOutput = item.json.output;\n  \n  // 1. Καθαρίζουμε τα Markdown Code Blocks αν υπάρχουν μέσα στο text\n  if (typeof rawOutput === 'string') {\n    rawOutput = rawOutput.replace(/```json/g, '').replace(/```/g, '').trim();\n  }\n  \n  try {\n    // 2. Μετατρέπουμε το string \"output\" σε πραγματικό JSON Object\n    const parsedData = JSON.parse(rawOutput);\n    \n    // 3. Εξάγουμε τα πεδία και τα κάνουμε flat στο item.json\n    item.json.is_feature_request = parsedData.feature_request === true;\n    item.json.feature_summary = parsedData.feature_summary || \"\";\n    item.json.urgency = parsedData.urgency || \"Low\";\n    item.json.reasoning = parsedData.reasoning || \"\";\n    \n    // 4. Εξαγωγή του email μέσα από το parsed output string\n    item.json.Customer_Email = parsedData.customer_email \n      ? parsedData.customer_email.trim().toLowerCase() \n      : \"anonymous\";\n    \n  } catch (error) {\n    item.json.is_feature_request = false;\n    item.json.parse_error = \"Failed to parse AI output string: \" + error.message;\n  }\n}\n\nreturn $input.all();"
      },
